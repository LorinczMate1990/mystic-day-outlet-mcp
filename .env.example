# --- backend ---
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_SECURE=true
EMAIL_IMAP_USER=user@example.com
EMAIL_IMAP_PASSWORD=changeme
# Set to true to log the raw IMAP protocol exchange (credentials are redacted by imapflow itself)
EMAIL_IMAP_DEBUG=false
# IMAP mailbox drafts are appended to
EMAIL_DRAFTS_MAILBOX=Drafts

# Origin allowed to call the backend via CORS (the frontend dev server / origin)
FRONTEND_URL=http://localhost:5173

# --- postgres ---
# Host path the Postgres data directory is bind-mounted from (the physical volume location)
POSTGRES_DATA_PATH=./data/postgres
POSTGRES_DB=mystic_day_outlet
POSTGRES_USER=mystic
POSTGRES_PASSWORD=changeme
# Host port Postgres is exposed on (the container always listens on 5432 internally)
POSTGRES_PORT=5432

# --- backend db connection (MikroORM) ---
# Hostname/port the backend uses to reach Postgres (the "postgres" service name on the compose network)
DB_HOST=postgres
DB_PORT=5432

# --- frontend ---
# Baked into the frontend build at build time.
VITE_API_BASE_URL=http://localhost:7000
